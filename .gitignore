# Python
__pycache__/
*.py[cod]
*.pyo
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/
.eggs/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data files (large raw data)
data/raw/*.csv
data/raw/*.json

# But DO track nyt_polls.csv so the scraper's append-mode merge has a
# baseline to read from. Without this tracked, every cron starts fresh
# and we lose any poll NYT has removed since the previous run. Added
# 2026-06-24 after NY-13 polls silently disappeared.
!data/raw/nyt_polls.csv
data/raw/*.parquet

# Transient scrutiny cache (rebuilt each run; not source of truth)
data/processed/scrutiny_cache.json

# Environment
.env
.env.*

# IDE
.vscode/
.idea/
*.swp

# Stray log files from dev runs (e.g. polymarket.log) — never check in
*.log

# OS
.DS_Store
Thumbs.db
